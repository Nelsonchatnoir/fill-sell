{
  "manifest_version": 3,
  "name": "FillSell — Cross-post",
  "version": "0.4.0",
  "description": "Publie automatiquement vos annonces FillSell sur Vinted, Leboncoin, Beebs et eBay.",
  "permissions": ["storage", "alarms", "scripting"],
  "host_permissions": [
    "https://*.vinted.fr/*",
    "https://*.vinted.com/*",
    "https://*.leboncoin.fr/*",
    "https://*.ebay.fr/*",
    "https://*.ebay.com/*",
    "https://*.beebs.app/*",
    "https://fillsell.app/*",
    "https://tojihnuawsoohlolangc.supabase.co/*"
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FillSell",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://fillsell.app/*"],
      "js": ["content-scripts/fillsell-auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.vinted.fr/*", "https://*.vinted.com/*"],
      "js": ["content-scripts/vinted.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.leboncoin.fr/*"],
      "js": ["content-scripts/leboncoin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.ebay.fr/*"],
      "js": ["content-scripts/ebay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.beebs.app/*"],
      "js": ["content-scripts/beebs.js"],
      "run_at": "document_idle"
    }
  ]
}
